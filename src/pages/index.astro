---
import Layout from '../layouts/Layout.astro';
import Redes from '../components/Redes.astro';
import Especial from '../components/Especial.astro';
import Tecnologys from '../components/Tecnologys.astro';
import Banner from '../components/Banner.astro';
import Form from '../components/Form.astro';
import Footer from '../components/Footer.astro';
import Projects from '../components/Projects.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<Layout title="Joaquín León Quero — Portafolio">
  <main>
    <Banner />
    <Projects />

    <section class="scroll-mt-24 border-b border-white/5 py-20 md:py-28" id="sobre-mi">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <SectionHeading
          eyebrow="Quién soy"
          title="Sobre mí"
          subtitle="Formación en Ingeniería en Gestión de TI (UVEG), más de cinco años en TI, proyectos en banca y producto digital, y uso de agentes de IA para acelerar el desarrollo sin sustituir el criterio técnico."
        />
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-lg leading-relaxed text-slate-400">
            Llevo más de cinco años en TI, con experiencia en varios proyectos de banca y producto digital.
            He usado de forma recurrente Angular, Nest, Node, Next, Astro, Flutter, Linux, Docker y nube,
            entre otras herramientas, y sigo ampliando stack por curiosidad y por necesidad del proyecto.
            Me importa empatizar con el equipo y dejar entregas claras para negocio y para quien mantenga
            el código después. Uso agentes de IA en el flujo de trabajo (IDE, revisiones, pruebas de
            ideas y documentación) para ganar productividad en el codeo; la decisión final y la calidad
            siguen siendo responsabilidad consciente del equipo.
          </p>
        </div>
        <div class="mt-14">
          <Redes />
        </div>
      </div>
    </section>

    <section class="scroll-mt-24 py-20 md:py-28" id="servicios">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <SectionHeading
          eyebrow="Cómo puedo ayudarte"
          title="Servicios"
          subtitle="Enfoque en negocio y resultados: digitalización, producto a medida y acompañamiento. El detalle técnico lo ves en cada proyecto."
        />
        <Especial />
      </div>
    </section>

    <section class="scroll-mt-24 border-y border-white/5 bg-white/[0.02] py-20 md:py-28" id="stack">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <SectionHeading
          eyebrow="Herramientas"
          title="Stack principal"
          subtitle="Tecnologías que uso con frecuencia en producto, backend y despliegue."
        />
        <Tecnologys />
      </div>
    </section>

    <section class="scroll-mt-24 py-20 md:pb-12" id="contacto">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <SectionHeading
          eyebrow="Hablemos"
          title="Contacto"
          subtitle="Cuéntame tu idea, tu equipo o tu reto técnico. Respondo con propuesta y siguientes pasos."
        />
        <Form />
      </div>
      <Footer />
    </section>
  </main>
</Layout>
