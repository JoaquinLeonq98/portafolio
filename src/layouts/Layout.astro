---
import '@fontsource-variable/onest';
import Header from '../components/Header.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Joaquín León Quero — Ingeniero en Gestión de TI. Más de 3 años en TI, proyectos en banca, full-stack (Angular, Nest, Node, Flutter), QA y despliegues. Portafolio y contacto.',
} = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#020617" />
    <title>{title}</title>
  </head>
  <body
    class="min-h-screen antialiased selection:bg-sky-500/30 selection:text-white bg-slate-950 text-slate-100 motion-body"
  >
    <div
      class="pointer-events-none fixed inset-0 -z-10 overflow-hidden"
      aria-hidden="true"
    >
      <div
        class="absolute -top-40 left-1/2 h-[520px] w-[900px] -translate-x-1/2 rounded-full bg-gradient-to-br from-sky-500/20 via-violet-600/15 to-transparent blur-3xl"
      />
      <div
        class="absolute bottom-0 right-0 h-96 w-96 translate-x-1/3 translate-y-1/3 rounded-full bg-violet-600/10 blur-3xl"
      />
      <div
        class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:64px_64px]"
      />
    </div>
    <Header />
    <slot />
  </body>
</html>

<style is:global>
  html {
    font-family: 'Onest Variable', system-ui, sans-serif;
  }

  @media (prefers-reduced-motion: no-preference) {
    /* El hero (#inicio) usa su propia animación; el resto entra al hacer scroll */
    .motion-body main > section:not(#inicio),
    .motion-body main > :global(section:not(#inicio)) {
      --reveal-y: 18px;
      --reveal-dur: 0.65s;
      opacity: 0;
      transform: translate3d(0, var(--reveal-y), 0);
      transition:
        opacity var(--reveal-dur) cubic-bezier(0.22, 1, 0.36, 1),
        transform var(--reveal-dur) cubic-bezier(0.22, 1, 0.36, 1);
    }

    .motion-body main > section:not(#inicio).motion-visible,
    .motion-body main > :global(section:not(#inicio).motion-visible) {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }

    .motion-body .motion-hero > * {
      opacity: 0;
      transform: translate3d(0, 14px, 0);
      animation: heroIn 0.75s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .motion-body .motion-hero > *:nth-child(1) {
      animation-delay: 0.05s;
    }
    .motion-body .motion-hero > *:nth-child(2) {
      animation-delay: 0.12s;
    }
    .motion-body .motion-hero > *:nth-child(3) {
      animation-delay: 0.18s;
    }
    .motion-body .motion-hero > *:nth-child(4) {
      animation-delay: 0.24s;
    }
    .motion-body .motion-hero > *:nth-child(5) {
      animation-delay: 0.3s;
    }
    .motion-body .motion-hero > *:nth-child(6) {
      animation-delay: 0.36s;
    }

    @keyframes heroIn {
      to {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .motion-body main > section,
    .motion-body main > :global(section),
    .motion-body .motion-hero > * {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }

    .project-card-animate,
    .tech-tile-animate,
    .tech-pill-animate,
    .service-card-animate {
      transition: none !important;
    }

    .project-card-animate:hover,
    .tech-tile-animate:hover,
    .tech-pill-animate:hover,
    .service-card-animate:hover {
      transform: none !important;
      box-shadow: none !important;
    }
  }

  .motion-body main > section#inicio {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .project-card-animate {
      transition:
        transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
        box-shadow 0.45s ease,
        border-color 0.35s ease;
    }

    .project-card-animate:hover {
      transform: translateY(-6px);
      box-shadow: 0 28px 56px -32px rgba(56, 189, 248, 0.25);
      border-color: rgba(56, 189, 248, 0.38);
    }

    .tech-tile-animate {
      transition:
        transform 0.35s ease,
        border-color 0.35s ease,
        background-color 0.35s ease;
    }

    .tech-tile-animate:hover {
      transform: translateY(-5px) scale(1.02);
      border-color: rgba(56, 189, 248, 0.4);
      background-color: rgba(255, 255, 255, 0.055);
    }

    .tech-tile-animate:hover .tech-logo-mark {
      transform: scale(1.1) translateY(-2px);
    }

    .tech-pill-animate {
      transition:
        transform 0.28s ease,
        border-color 0.28s ease,
        background-color 0.28s ease;
    }

    .tech-pill-animate:hover {
      transform: scale(1.07);
      border-color: rgba(125, 211, 252, 0.45);
      background-color: rgba(255, 255, 255, 0.08);
    }

    .tech-pill-animate:hover .tech-pill-icon {
      transform: scale(1.12);
    }

    .tech-pill-icon {
      transition: transform 0.28s ease;
    }

    .service-card-animate {
      transition:
        transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
        border-color 0.35s ease,
        box-shadow 0.4s ease,
        background-color 0.35s ease;
    }

    .service-card-animate:hover {
      transform: translateY(-5px);
      border-color: rgba(56, 189, 248, 0.35);
      box-shadow: 0 24px 48px -36px rgba(56, 189, 248, 0.2);
      background-color: rgba(255, 255, 255, 0.045);
    }

    @keyframes portfolioTileIn {
      from {
        opacity: 0;
        transform: translateY(16px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    #proyectos.motion-visible .projects-grid-desktop > * {
      animation: portfolioTileIn 0.55s cubic-bezier(0.22, 1, 0.36, 1) backwards;
    }

    #proyectos.motion-visible .projects-grid-desktop > *:nth-child(1) {
      animation-delay: 0.05s;
    }
    #proyectos.motion-visible .projects-grid-desktop > *:nth-child(2) {
      animation-delay: 0.12s;
    }
    #proyectos.motion-visible .projects-grid-desktop > *:nth-child(3) {
      animation-delay: 0.19s;
    }

    #stack.motion-visible .motion-tech-stagger > * {
      animation: portfolioTileIn 0.48s cubic-bezier(0.22, 1, 0.36, 1) backwards;
    }

    #stack.motion-visible .motion-tech-stagger > *:nth-child(1) {
      animation-delay: 0.02s;
    }
    #stack.motion-visible .motion-tech-stagger > *:nth-child(2) {
      animation-delay: 0.05s;
    }
    #stack.motion-visible .motion-tech-stagger > *:nth-child(3) {
      animation-delay: 0.08s;
    }
    #stack.motion-visible .motion-tech-stagger > *:nth-child(4) {
      animation-delay: 0.11s;
    }
    #stack.motion-visible .motion-tech-stagger > *:nth-child(5) {
      animation-delay: 0.14s;
    }
    #stack.motion-visible .motion-tech-stagger > *:nth-child(6) {
      animation-delay: 0.17s;
    }
    #stack.motion-visible .motion-tech-stagger > *:nth-child(7) {
      animation-delay: 0.2s;
    }
    #stack.motion-visible .motion-tech-stagger > *:nth-child(8) {
      animation-delay: 0.23s;
    }
    #stack.motion-visible .motion-tech-stagger > *:nth-child(9) {
      animation-delay: 0.26s;
    }
    #stack.motion-visible .motion-tech-stagger > *:nth-child(10) {
      animation-delay: 0.29s;
    }
    #stack.motion-visible .motion-tech-stagger > *:nth-child(11) {
      animation-delay: 0.32s;
    }
    #stack.motion-visible .motion-tech-stagger > *:nth-child(12) {
      animation-delay: 0.35s;
    }
    #stack.motion-visible .motion-tech-stagger > *:nth-child(13) {
      animation-delay: 0.38s;
    }

    #servicios.motion-visible .services-grid > * {
      animation: portfolioTileIn 0.52s cubic-bezier(0.22, 1, 0.36, 1) backwards;
    }

    #servicios.motion-visible .services-grid > *:nth-child(1) {
      animation-delay: 0.04s;
    }
    #servicios.motion-visible .services-grid > *:nth-child(2) {
      animation-delay: 0.1s;
    }
    #servicios.motion-visible .services-grid > *:nth-child(3) {
      animation-delay: 0.16s;
    }
    #servicios.motion-visible .services-grid > *:nth-child(4) {
      animation-delay: 0.22s;
    }
  }
</style>

<script is:inline>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var sections = document.querySelectorAll('main section:not(#inicio)');
    if (!sections.length) return;
    var io = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            e.target.classList.add('motion-visible');
            io.unobserve(e.target);
          }
        });
      },
      { rootMargin: '0px 0px -8% 0px', threshold: 0.08 }
    );
    sections.forEach(function (s) {
      io.observe(s);
    });
  })();
</script>
