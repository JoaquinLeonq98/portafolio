---
import SectionHeading from './SectionHeading.astro';
import ProjectCarousel from './ProjectCarousel.astro';
---

<section class="scroll-mt-24 py-16 md:py-22" id="proyectos" aria-labelledby="proyectos-heading">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionHeading
      compact
      eyebrow="Casos reales"
      title="Proyectos"
      subtitle="Tres referencias recientes. En pantallas grandes se ven al mismo tiempo; en móvil, desliza o usa las flechas."
      id="proyectos-heading"
    />

    <ProjectCarousel />
  </div>
</section>
