---
import type { ProjectTech } from '../data/projectTech';
import { isRemoteTech } from '../data/projectTech';
import StackIcon from './icons/StackIcon.astro';

interface Props {
  title: string;
  excerpt: string;
  previewSrc: string;
  tech: ProjectTech[];
  href?: string;
  slug: string;
  previewFit?: 'cover' | 'contain';
  inDevelopment?: boolean;
  previewContainerClass?: string;
}

const {
  title,
  excerpt,
  previewSrc,
  tech,
  href,
  slug,
  previewFit = 'cover',
  inDevelopment = false,
  previewContainerClass,
} = Astro.props;
const detailHref = `/proyectos/${slug}`;
const visitHref = href?.trim();

const imgClass =
  previewFit === 'contain'
    ? 'absolute left-1/2 top-1/2 max-h-[76%] max-w-[76%] -translate-x-1/2 -translate-y-1/2 object-contain object-center'
    : 'absolute inset-0 h-full w-full object-cover object-center';

const previewOverlayClass =
  previewFit === 'contain'
    ? 'from-slate-950/35 via-transparent to-transparent opacity-75'
    : 'from-slate-950/65 via-transparent to-transparent opacity-90';
---

<article
  class="project-card-animate group relative flex h-full w-full min-w-0 flex-col overflow-hidden rounded-xl border border-white/10 bg-white/[0.03] shadow-[0_0_0_1px_rgba(255,255,255,0.04)] backdrop-blur-sm"
>
  <!-- Clic en casi toda la tarjeta → ficha del proyecto (enlace estirado bajo el contenido) -->
  <a
    href={detailHref}
    class="absolute inset-0 z-0 rounded-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500/60 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-950"
    aria-label={`Ver ficha completa: ${title}`}
  >
    <span class="sr-only">Abrir ficha del proyecto {title}</span>
  </a>

  <div class="relative z-[1] flex min-h-0 flex-1 flex-col pointer-events-none">
    <div
      class:list={[
        'relative aspect-[16/10] w-full max-h-[12rem] shrink-0 overflow-hidden sm:max-h-[13rem]',
        previewContainerClass?.trim() || 'bg-slate-900',
      ]}
    >
      {
        inDevelopment && (
          <span
            class="absolute right-2.5 top-2.5 z-[2] rounded-md border border-[#1e3d32]/50 bg-[#2d4a3e] px-2 py-1 text-[10px] font-semibold uppercase tracking-wider text-[#e8f4ec] shadow-md"
            aria-hidden="true"
          >
            En desarrollo
          </span>
        )
      }
      <img
        src={previewSrc}
        alt=""
        width={800}
        height={500}
        class={`${imgClass} transition duration-500 ease-out group-hover:scale-[1.03]`}
        loading="lazy"
        decoding="async"
      />
      <div
        class={`pointer-events-none absolute inset-0 bg-gradient-to-t ${previewOverlayClass}`}
        aria-hidden="true"
      />
    </div>

    <div class="flex min-h-0 flex-1 flex-col p-5 md:p-6">
      <h3 class="text-base font-semibold leading-snug tracking-tight text-white md:text-lg">
        {title}
      </h3>
      <p
        class="mt-3 line-clamp-3 flex-1 text-xs leading-relaxed text-slate-400 sm:line-clamp-4 sm:text-sm"
        title={excerpt}
      >
        {excerpt}
      </p>

      <div class="mt-5 flex flex-col gap-2 border-t border-white/10 pt-5">
        <span class="text-[10px] font-medium uppercase tracking-wider text-slate-500">Stack</span>
        <ul class="flex flex-wrap gap-2" aria-label="Tecnologías utilizadas">
          {tech.map((t) => (
            <li
              class="tech-pill-animate inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-white/5 px-2.5 py-1 text-[11px] font-medium text-slate-200"
            >
              {isRemoteTech(t) ? (
                <img
                  src={t.remoteIcon}
                  alt=""
                  class="tech-pill-icon h-3.5 w-3.5 object-contain"
                  width="14"
                  height="14"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <StackIcon id={t.icon} class="tech-pill-icon h-3.5 w-3.5 shrink-0" />
              )}
              {t.name}
            </li>
          ))}
        </ul>
      </div>

      <div class="relative z-[2] mt-5 flex flex-wrap items-center gap-x-5 gap-y-2 pointer-events-auto">
        <a
          href={detailHref}
          class="inline-flex w-fit items-center gap-1 text-xs font-medium text-violet-300 underline-offset-2 transition hover:text-violet-200 hover:underline"
        >
          Ficha completa
          <span aria-hidden="true">→</span>
        </a>
        {visitHref && (
          <a
            href={visitHref}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex w-fit items-center gap-1.5 text-xs font-medium text-sky-400 underline-offset-2 transition hover:text-sky-300 hover:underline"
          >
            Visitar sitio
            <span aria-hidden="true">↗</span>
          </a>
        )}
      </div>
    </div>
  </div>
</article>
