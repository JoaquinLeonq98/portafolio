---

---
<header
  class="sticky top-0 z-50 border-b border-white/5 bg-slate-950/80 backdrop-blur-md"
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4 sm:px-6" aria-label="Principal">
    <a
      href="/#inicio"
      class="text-sm font-semibold tracking-tight text-white transition hover:text-sky-400"
    >
      JLQ<span class="text-sky-400">.</span>
    </a>

    <button
      type="button"
      id="nav-toggle"
      class="inline-flex items-center justify-center rounded-lg border border-white/10 p-2 text-slate-300 md:hidden"
      aria-expanded="false"
      aria-controls="nav-panel"
      aria-label="Abrir menú"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16" />
      </svg>
    </button>

    <div
      id="nav-panel"
      class="absolute left-0 right-0 top-full hidden flex-col gap-1 border-b border-white/5 bg-slate-950/95 px-4 py-4 shadow-lg backdrop-blur-md md:static md:flex md:flex-row md:items-center md:gap-1 md:border-0 md:bg-transparent md:p-0 md:shadow-none"
    >
      <a
        class="rounded-lg px-3 py-2 text-sm text-slate-300 transition hover:bg-white/5 hover:text-white"
        href="/#inicio">Inicio</a>
      <a
        class="rounded-lg px-3 py-2 text-sm text-slate-300 transition hover:bg-white/5 hover:text-white"
        href="/#proyectos">Proyectos</a>
      <a
        class="rounded-lg px-3 py-2 text-sm text-slate-300 transition hover:bg-white/5 hover:text-white"
        href="/#sobre-mi">Sobre mí</a>
      <a
        class="rounded-lg px-3 py-2 text-sm text-slate-300 transition hover:bg-white/5 hover:text-white"
        href="/#servicios">Servicios</a>
      <a
        class="rounded-lg px-3 py-2 text-sm text-slate-300 transition hover:bg-white/5 hover:text-white"
        href="/#stack">Stack</a>
      <a
        class="rounded-lg px-3 py-2 text-sm font-medium text-sky-400 transition hover:bg-sky-500/10"
        href="/#contacto">Contacto</a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const panel = document.getElementById('nav-panel');

  toggle?.addEventListener('click', () => {
    panel?.classList.toggle('hidden');
    const open = panel ? !panel.classList.contains('hidden') : false;
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
  });

  panel?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      if (window.matchMedia('(max-width: 767px)').matches) {
        panel.classList.add('hidden');
        toggle?.setAttribute('aria-expanded', 'false');
        toggle?.setAttribute('aria-label', 'Abrir menú');
      }
    });
  });
</script>
